{
  "info": {
    "name": "Banking - Customer Service",
    "description": "Customer identity management endpoints for the Banking microservices system.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "customerId",
      "value": "CUST1001"
    }
  ],
  "item": [
    {
      "name": "Create Customer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": \"CUST1001\",\n  \"name\": \"Asha Rao\",\n  \"email\": \"asha@example.com\",\n  \"phoneNumber\": \"9876543210\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/customers",
          "host": ["{{baseUrl}}"],
          "path": ["customers"]
        }
      }
    },
    {
      "name": "Get Customer By CustomerId",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/customers/{{customerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["customers", "{{customerId}}"]
        }
      }
    },
    {
      "name": "Create Customer - Invalid Phone (400)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": \"CUST1002\",\n  \"name\": \"Bad Phone\",\n  \"email\": \"bad@example.com\",\n  \"phoneNumber\": \"12345\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/customers",
          "host": ["{{baseUrl}}"],
          "path": ["customers"]
        }
      }
    },
    {
      "name": "Create Customer - Duplicate (409)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": \"CUST1001\",\n  \"name\": \"Asha Rao\",\n  \"email\": \"asha@example.com\",\n  \"phoneNumber\": \"9876543210\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/customers",
          "host": ["{{baseUrl}}"],
          "path": ["customers"]
        }
      }
    },
    {
      "name": "Get Customer - Not Found (404)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/customers/CUST9999",
          "host": ["{{baseUrl}}"],
          "path": ["customers", "CUST9999"]
        }
      }
    }
  ]
}
